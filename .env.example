# NesterVoiceAI Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# API Keys (Required)
# ===========================================

# Deepgram - Speech-to-Text and Text-to-Speech
# Get your key at: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OpenAI - LLM for conversation
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# API Keys (Optional - based on config)
# ===========================================

# Google AI - Alternative LLM provider
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Hume AI - Emotion Detection from Voice
# Get your key at: https://platform.hume.ai/
# Free tier: 5 EVI minutes/month, $3 Starter = 40 minutes
HUME_API_KEY=your_hume_api_key_here

# ElevenLabs - Alternative TTS provider
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Cartesia - TTS with word timestamps and emotion control (sonic-3)
# Get your key at: https://play.cartesia.ai/
# Get voice IDs at: https://play.cartesia.ai/voices
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=your_cartesia_voice_id_here

# Resemble AI - Chatterbox TTS with emotion control (feat/resemble-tts branch)
# Get your key at: https://app.resemble.ai/
RESEMBLE_API_KEY=your_resemble_api_key_here

# Picovoice Koala - Noise suppression for audio input
# Get your key at: https://console.picovoice.ai/
KOALA_ACCESS_KEY=your_koala_access_key_here

# Tally.so - Appointment booking form submissions
# Get your API key at: https://tally.so/help/api
# Required for voice appointment booking feature
TALLY_API_KEY=your_tally_api_key_here

# ===========================================
# Server Configuration
# ===========================================

# FastAPI server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=7860

# WebSocket server
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8765
WEBSOCKET_SERVER=websocket_server

# Session settings
SESSION_TIMEOUT=180
LOG_LEVEL=INFO

# ===========================================
# Production Settings (for HTTPS deployment)
# ===========================================

# Your domain name (for Caddy HTTPS)
# Examples: yourdomain.com, nester.example.com, 1.2.3.4.nip.io
DOMAIN=localhost

# Public URL for WebSocket connections
# Should match your domain with https://
PUBLIC_URL=https://yourdomain.com

# ===========================================
# Audio Processing (Optional)
# ===========================================

# ai-coustics (AIC Speech Enhancement)
AIC_LICENSE_KEY=your_aic_license_key_here

# ===========================================
# ngrok Configuration (for public access)
# ===========================================

# ngrok authtoken (get from https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Optional: Custom ngrok domain (requires paid plan)
# NGROK_DOMAIN=your-custom-domain.ngrok-free.app
