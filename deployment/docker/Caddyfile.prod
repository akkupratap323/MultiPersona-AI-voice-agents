# Production Caddyfile for NesterConversationalBot
# This file is synced to /opt/nester/Caddyfile during deployment
# Caddy automatically handles SSL certificates via Let's Encrypt

ai.nesterlabs.com {
    # API endpoints - proxy to backend (MUST be before catch-all)
    handle /health* {
        reverse_proxy backend:7860
    }

    handle /connect* {
        reverse_proxy backend:7860
    }

    handle /status* {
        reverse_proxy backend:7860
    }

    handle /a2ui/* {
        reverse_proxy backend:7860
    }

    handle /graph/* {
        reverse_proxy backend:7860
    }

    handle /docs* {
        reverse_proxy backend:7860
    }

    # WebSocket endpoint - route to FastAPI server
    handle /ws* {
        reverse_proxy backend:7860 {
            header_up Connection {header.Connection}
            header_up Upgrade {header.Upgrade}
            # Disable buffering for real-time streaming
            flush_interval -1
            # Keep connection alive for long-running sessions
            transport http {
                keepalive 30s
                keepalive_idle_conns 10
            }
        }
    }

    # Frontend - catch-all for static files and SPA routes (MUST be last)
    handle {
        reverse_proxy frontend:80
    }

    # Security headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Enable compression
    encode gzip

    # Logging
    log {
        output stdout
        format console
    }
}

# Redirect nip.io domain to production domain
# The IP will be dynamically determined, but we can add common patterns
# Note: Caddy will only respond to domains it's configured for
# The actual nip.io redirect is added dynamically on the server