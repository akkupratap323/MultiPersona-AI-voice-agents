# Production Caddyfile — MultiPersona AI Voice Agents
# Synced to /opt/voice-ai/Caddyfile during deployment
# Caddy automatically obtains SSL certificates via Let's Encrypt
# Replace yourdomain.com with your actual domain

3.6.92.112.nip.io {
    # API endpoints - proxy to backend (MUST be before catch-all)
    handle /health* {
        reverse_proxy backend:7860
    }

    handle /connect* {
        reverse_proxy backend:7860
    }

    handle /status* {
        reverse_proxy backend:7860
    }

    handle /a2ui/* {
        reverse_proxy backend:7860
    }

    handle /graph/* {
        reverse_proxy backend:7860
    }

    handle /docs* {
        reverse_proxy backend:7860
    }

    # WebSocket endpoint - route to FastAPI server
    handle /ws* {
        reverse_proxy backend:7860 {
            header_up Connection {header.Connection}
            header_up Upgrade {header.Upgrade}
            # Disable buffering for real-time streaming
            flush_interval -1
            # Keep connection alive for long-running sessions
            transport http {
                keepalive 30s
                keepalive_idle_conns 10
            }
        }
    }

    # Frontend - catch-all for static files and SPA routes (MUST be last)
    handle {
        reverse_proxy frontend:80
    }

    # Security headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Enable compression
    encode gzip

    # Logging
    log {
        output stdout
        format console
    }
}

# To use a raw IP (no domain), replace yourdomain.com above with:
# :80 { ... }  — but you won't get HTTPS without a domain